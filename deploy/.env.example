# Argosy dev stack — copy to deploy/.env and adjust as needed.
# (docker compose reads deploy/.env automatically.)

# Host port for the Argosy server (the container always listens on 8096).
# 8096 is the production container; use 8097 for the dev stack to avoid a clash.
ARGOSY_HOST_PORT=8097

# PostgreSQL. construct-server already uses host 5432 (loopback), so default
# the host mapping to 5433. The server reaches Postgres in-network on 5432.
POSTGRES_USER=argosy
POSTGRES_PASSWORD=changeme   # dev-only placeholder — set a real secret for any non-local use
POSTGRES_DB=argosy
POSTGRES_HOST_PORT=5433

# Host directory with your media library, mounted read-only at /media.
ARGOSY_MEDIA_DIR_HOST=./sample-media

# Optional Vite dev server (enabled via `make compose-web`).
WEB_HOST_PORT=5173
