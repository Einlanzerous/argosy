# Dev image: Go toolchain + air (hot reload) + ffmpeg/ffprobe + Intel QSV/VAAPI.
# The source tree is bind-mounted by docker-compose; this image only provides
# the toolchain, so code edits rebuild in-container without an image rebuild.
FROM golang:1.26-bookworm

# ffmpeg plus the Intel runtime for hardware encode (ARGY-30): the iHD VA driver
# + the Media SDK (libmfx) dispatcher that h264_qsv talks to, and vainfo for
# diagnostics. intel-media-va-driver-non-free lives in Debian's non-free.
RUN sed -i 's/Components: main/Components: main contrib non-free non-free-firmware/' \
      /etc/apt/sources.list.d/debian.sources \
 && apt-get update \
 && apt-get install -y --no-install-recommends \
      ffmpeg \
      intel-media-va-driver-non-free \
      libmfx1 \
      libva2 \
      libva-drm2 \
      vainfo \
 && rm -rf /var/lib/apt/lists/*

# Force the modern iHD driver (UHD 630 is Gen9.5) rather than legacy i965.
ENV LIBVA_DRIVER_NAME=iHD

# air for live reload (github.com/air-verse/air is the maintained fork).
RUN go install github.com/air-verse/air@latest

WORKDIR /app
EXPOSE 8096

CMD ["air", "-c", ".air.toml"]
